<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FRST_project</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FRST_project.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="site-nav">
            <div class="site-nav__inner">
                <a class="site-nav__brand" asp-area="" asp-controller="Home" asp-action="Index">FRST_project</a>
                <div class="site-nav__links">
                    <a class="site-nav__link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                    <a class="site-nav__link" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                </div>
            </div>
        </nav>
    </header>
    <div class="page">
        <main role="main" class="page__content">
            @RenderBody()
        </main>
    </div>

    <footer class="site-footer">
        <div class="site-footer__inner">
            &copy; 2026 - FRST_project - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
